# RPC endpoint (Alchemy, Infura, Quicknode)
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/ТВОЙ_КЛЮЧ

# Приватный ключ Arb Owner (без 0x)
ARB_OWNER_PRIVATE_KEY=твой_приватный_ключ_здесь

# Отдельный ключ для аутентификации в Flashbots
# Не должен иметь средств, просто идентификатор репутации
# Сгенерируй через: node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
FLASHBOTS_AUTH_KEY=0x00000

# Адрес твоего деплоенного контракта
ARB_CONTRACT_ADDRESS=0xТВОЙ_АДРЕС_КОНТРАКТА

# Минимальная прибыль в USDC (с учётом 6 decimals: 10 USDC = 10000000)
MIN_PROFIT_USDC=10000000

# Сумма займа в USDC (10 000 USDC)
LOAN_AMOUNT_USDC=10000000000
