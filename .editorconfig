root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4

[*.java]
max_line_length = 120
ij_java_indent_size = 4
ij_java_continuation_indent_size = 4
ij_java_tab_size = 4

[*.gradle]
indent_size = 4
ij_kotlin_indent_size = 4

[*.kt]
indent_size = 4
ij_kotlin_indent_size = 4
ij_kotlin_continuation_indent_size = 4
ij_kotlin_tab_size = 4

[*.{xml,properties}]
indent_size = 4

[*.yml]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
